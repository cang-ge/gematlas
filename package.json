{
  "name": "gematlas",
  "version": "1.0.0",
  "private": true,
  "description": "GemAtlas — open-source gemological knowledge platform (bilingual EN/ZH). Data-layer deps (zod, js-yaml, tsx, vitest) and chart deps (echarts, mermaid) are added in their respective phases, not pre-installed.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs",
    "validate:data": "tsx scripts/build/validate-data.ts",
    "sync:content": "tsx scripts/build/sync-content.ts",
    "generate:pages": "tsx scripts/build/generate-gem-pages.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.5.1",
    "cytoscape": "^3.34.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "debug": "^4.4.3",
    "js-yaml": "^4.1.0",
    "mermaid": "^11.16.0",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.2",
    "vue": "^3.5.39",
    "zod": "^3.23.8"
  }
}